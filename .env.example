# Copy to .env and fill in values.

# Pinecone (vectors are stored here; required for /query RAG)
PINECONE_API_KEY=
PINECONE_INDEX=rag-data-structures
PINECONE_NAMESPACE=neobank-kb
# Optional: override if you change Ollama embedding model (default follows embedding_service.EMBEDDING_DIMENSION)
# PINECONE_EMBEDDING_DIMENSION=1024
# Serverless index creation (first run only, if the index does not exist yet)
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# LlamaCloud PDF parsing (ingest)
LLAMA_CLOUD_API_KEY=
